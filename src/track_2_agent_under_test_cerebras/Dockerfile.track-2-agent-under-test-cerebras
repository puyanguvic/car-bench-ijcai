FROM ghcr.io/astral-sh/uv:python3.12-trixie-slim@sha256:3137a0b606f65a74ee0245f43dae219b09e8af98fc37fef20841cbceef35a646 AS python-deps

RUN adduser --disabled-password --gecos "" carbench
USER carbench
RUN mkdir -p /home/carbench/.cache/uv
WORKDIR /home/carbench/app

COPY --chown=carbench:carbench pyproject.toml uv.lock README.md ./

RUN \
    --mount=type=cache,target=/home/carbench/.cache/uv,uid=1000 \
    uv sync --frozen --no-install-project --no-dev --extra track-2-agent

FROM python:3.12-slim-trixie@sha256:423ed6ab25b1921a477529254bfeeabf5855151dc2c3141699a1bfc852199fbf

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/* \
    && adduser --disabled-password --gecos "" carbench
USER carbench
WORKDIR /home/carbench/app

COPY --from=python-deps --chown=carbench:carbench /home/carbench/app/.venv .venv

# Ship only the PACT runtime dependency closure.  In particular, the legacy
# rule controller and legacy Track 2 executor are not present in the release
# image, so they cannot become an accidental alternate execution path.
COPY --chown=carbench:carbench \
    src/logging_utils.py \
    src/tool_call_types.py \
    src/turn_metrics.py \
    src/
COPY --chown=carbench:carbench \
    src/carbench_agent_core/__init__.py \
    src/carbench_agent_core/evidence_ledger.py \
    src/carbench_agent_core/obligation_runtime.py \
    src/carbench_agent_core/plan_ir.py \
    src/carbench_agent_core/plan_verifier.py \
    src/carbench_agent_core/response_renderer.py \
    src/carbench_agent_core/semantic_compiler.py \
    src/carbench_agent_core/tool_index.py \
    src/carbench_agent_core/
COPY --chown=carbench:carbench \
    src/track_2_agent_under_test_cerebras/__init__.py \
    src/track_2_agent_under_test_cerebras/cerebras_client.py \
    src/track_2_agent_under_test_cerebras/pact_agent.py \
    src/track_2_agent_under_test_cerebras/plan_compiler_backend.py \
    src/track_2_agent_under_test_cerebras/server.py \
    src/track_2_agent_under_test_cerebras/

ENV PYTHONPATH=/home/carbench/app/src
ENV PACT_COMPILER_MODEL=gpt-oss-120b
ENV PACT_COMPILER_REASONING_EFFORT=medium
ENV PACT_COMPILER_MAX_COMPLETION_TOKENS=8192
ENV PACT_COMPILER_SEMANTIC_REVIEW=true

ENTRYPOINT [".venv/bin/python", "src/track_2_agent_under_test_cerebras/server.py"]
CMD ["--host", "0.0.0.0"]
EXPOSE 8080

FROM ghcr.io/astral-sh/uv:python3.12-trixie-slim@sha256:3137a0b606f65a74ee0245f43dae219b09e8af98fc37fef20841cbceef35a646 AS python-deps

RUN adduser --disabled-password --gecos "" carbench
USER carbench
RUN mkdir -p /home/carbench/.cache/uv
WORKDIR /home/carbench/app

COPY --chown=carbench:carbench pyproject.toml uv.lock README.md ./

RUN \
    --mount=type=cache,target=/home/carbench/.cache/uv,uid=1000 \
    uv sync --frozen --no-install-project --no-dev --extra track-2-agent

FROM python:3.12-slim-trixie@sha256:423ed6ab25b1921a477529254bfeeabf5855151dc2c3141699a1bfc852199fbf

RUN adduser --disabled-password --gecos "" carbench
USER carbench
WORKDIR /home/carbench/app

COPY --from=python-deps --chown=carbench:carbench /home/carbench/app/.venv .venv
COPY --chown=carbench:carbench src src

ENV PYTHONPATH=/home/carbench/app/src
ENV TRACK2_PLANNER_MODEL=gpt-oss-120b
ENV TRACK2_PLANNER_REASONING_EFFORT=high
ENV TRACK2_EXECUTOR_MODEL=gpt-oss-120b
ENV TRACK2_EXECUTOR_REASONING_EFFORT=medium

ENTRYPOINT [".venv/bin/python", "src/track_2_agent_under_test_cerebras_planner/server.py"]
CMD ["--host", "0.0.0.0"]
EXPOSE 8080

ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LOGURU_LEVEL=DEBUG
LOG_FORMAT=text
OPENAI_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# Track 2 PACT semantic compiler (direct Cerebras SDK).
CEREBRAS_API_KEY=
PACT_COMPILER_MODEL=gpt-oss-120b
PACT_COMPILER_CEREBRAS_API_BASE=https://api.cerebras.ai
PACT_COMPILER_SERVICE_TIER=
PACT_COMPILER_REASONING_EFFORT=low
PACT_COMPILER_MAX_COMPLETION_TOKENS=4096
PACT_COMPILER_TEMPERATURE=
PACT_COMPILER_MAX_REPAIR_ATTEMPTS=1
PACT_COMPILER_MAX_NODES=20
PACT_COMPILER_MAX_DEPENDENCY_DEPTH=12
PACT_COMPILER_MAX_POLICY_CHARS=64000
PACT_COMPILER_MAX_GOAL_CHARS=12000
PACT_COMPILER_MAX_USER_EVENT_CHARS=12000
PACT_COMPILER_MAX_CONVERSATION_MESSAGES=32
PACT_COMPILER_MAX_CONVERSATION_CHARS=64000
PACT_COMPILER_MAX_CONTEXT_CHARS=96000
PACT_COMPILER_MAX_CANDIDATE_CHARS=64000
PACT_COMPILER_MAX_EVIDENCE_RECORDS=128
PACT_CEREBRAS_MAX_RATE_LIMIT_RETRIES=3
PACT_CEREBRAS_MAX_RATE_LIMIT_WAIT_SECONDS=600
PACT_CEREBRAS_QUEUE_BACKOFF_SECONDS=60
PACT_CEREBRAS_QUEUE_BACKOFF_INITIAL_JITTER_RATIO=0.1
PACT_CEREBRAS_QUEUE_BACKOFF_SECOND_MIN_SECONDS=90
PACT_CEREBRAS_QUEUE_BACKOFF_SECOND_MAX_SECONDS=120
PACT_CEREBRAS_QUEUE_BACKOFF_CAP_MIN_SECONDS=180
PACT_CEREBRAS_QUEUE_BACKOFF_CAP_MAX_SECONDS=300
PACT_CEREBRAS_RATE_LIMIT_RETRY_BUFFER_SECONDS=1
PACT_CEREBRAS_PROACTIVE_TOKEN_PACING=true
PACT_CEREBRAS_TOKEN_QUOTA_WINDOW_SECONDS=60
CAR_BENCH_CEREBRAS_RATE_LIMIT_REPORT_DIR=/tmp/car-bench-rate-limit-reports

ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LOGURU_LEVEL=DEBUG
LOG_FORMAT=text
OPENAI_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# Track 2 Cerebras direct executor.
CEREBRAS_API_KEY=
TRACK2_EXECUTOR_MODEL=cerebras/gpt-oss-120b
TRACK2_CEREBRAS_API_BASE=https://api.cerebras.ai/v1
TRACK2_CEREBRAS_SERVICE_TIER=
TRACK2_MAX_COMPLETION_TOKENS=1024
TRACK2_TEMPERATURE=0
TRACK2_LLM_MIN_INTERVAL_SECONDS=0
TRACK2_LLM_REQUESTS_PER_MINUTE=
TRACK2_LLM_REQUESTS_PER_HOUR=
TRACK2_LLM_REQUESTS_PER_DAY=
TRACK2_LLM_TOKENS_PER_MINUTE=
TRACK2_LLM_TOKENS_PER_HOUR=
TRACK2_LLM_TOKENS_PER_DAY=
TRACK2_LLM_TOKEN_ESTIMATE_CHARS_PER_TOKEN=4
TRACK2_LLM_TOKEN_SAFETY_FACTOR=1.1
TRACK2_LLM_MAX_SCHEDULE_WAIT_SECONDS=
TRACK2_CEREBRAS_QUEUE_BACKOFF_SECONDS=60
TRACK2_CEREBRAS_RATE_LIMIT_RETRY_BUFFER_SECONDS=1
CAR_BENCH_CEREBRAS_RATE_LIMIT_REPORT_DIR=/tmp/car-bench-rate-limit-reports
TRACK2_CEREBRAS_RAW_ERROR_PROBE=0
TRACK2_CEREBRAS_RAW_ERROR_PROBE_TIMEOUT_SECONDS=30
TRACK2_LLM_MALFORMED_RETRIES=1

# Track 2 planner/executor template. Use the LiteLLM route available to you,
# for example openai/gpt-5.5 or azure/gpt-5.5.
TRACK2_PLANNER_MODEL=
TRACK2_PLANNER_MAX_COMPLETION_TOKENS=2048

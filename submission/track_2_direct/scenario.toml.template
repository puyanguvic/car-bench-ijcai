# CAR-bench Track 2 final submission: direct Cerebras executor.
# Replace the image placeholder with a public, linux/amd64 GHCR digest before
# submission. Do not put secret values in this file.

[evaluator]
image = "ghcr.io/car-bench/car-bench-evaluator:latest"

[evaluator.env]
GEMINI_API_KEY = "${GEMINI_API_KEY:?Set GEMINI_API_KEY}"
LOGURU_LEVEL = "${LOGURU_LEVEL:-INFO}"

[agent_under_test]
image = "ghcr.io/puyanguvic/car-bench-track-2-direct@sha256:REPLACE_WITH_PUBLIC_IMAGE_DIGEST"

[agent_under_test.env]
CEREBRAS_API_KEY = "${CEREBRAS_API_KEY:?Set CEREBRAS_API_KEY}"
TRACK2_CEREBRAS_API_BASE = "${TRACK2_CEREBRAS_API_BASE:-https://api.cerebras.ai}"
TRACK2_EXECUTOR_MODEL = "${TRACK2_EXECUTOR_MODEL:-gpt-oss-120b}"
TRACK2_EXECUTOR_REASONING_EFFORT = "${TRACK2_EXECUTOR_REASONING_EFFORT:-medium}"
TRACK2_CEREBRAS_SERVICE_TIER = "${TRACK2_CEREBRAS_SERVICE_TIER:-}"
TRACK2_MAX_COMPLETION_TOKENS = "${TRACK2_MAX_COMPLETION_TOKENS:-1024}"
TRACK2_TEMPERATURE = "${TRACK2_TEMPERATURE:-}"
TRACK2_PROMPT_HISTORY_MAX_MESSAGES = "${TRACK2_PROMPT_HISTORY_MAX_MESSAGES:-24}"
TRACK2_CEREBRAS_QUEUE_BACKOFF_SECONDS = "${TRACK2_CEREBRAS_QUEUE_BACKOFF_SECONDS:-60}"
TRACK2_CEREBRAS_QUEUE_BACKOFF_INITIAL_JITTER_RATIO = "${TRACK2_CEREBRAS_QUEUE_BACKOFF_INITIAL_JITTER_RATIO:-0.1}"
TRACK2_CEREBRAS_QUEUE_BACKOFF_SECOND_MIN_SECONDS = "${TRACK2_CEREBRAS_QUEUE_BACKOFF_SECOND_MIN_SECONDS:-90}"
TRACK2_CEREBRAS_QUEUE_BACKOFF_SECOND_MAX_SECONDS = "${TRACK2_CEREBRAS_QUEUE_BACKOFF_SECOND_MAX_SECONDS:-120}"
TRACK2_CEREBRAS_QUEUE_BACKOFF_CAP_MIN_SECONDS = "${TRACK2_CEREBRAS_QUEUE_BACKOFF_CAP_MIN_SECONDS:-180}"
TRACK2_CEREBRAS_QUEUE_BACKOFF_CAP_MAX_SECONDS = "${TRACK2_CEREBRAS_QUEUE_BACKOFF_CAP_MAX_SECONDS:-300}"
TRACK2_CEREBRAS_RATE_LIMIT_RETRY_BUFFER_SECONDS = "${TRACK2_CEREBRAS_RATE_LIMIT_RETRY_BUFFER_SECONDS:-1}"
TRACK2_CEREBRAS_PROACTIVE_TOKEN_PACING = "${TRACK2_CEREBRAS_PROACTIVE_TOKEN_PACING:-true}"
TRACK2_CEREBRAS_TOKEN_QUOTA_WINDOW_SECONDS = "${TRACK2_CEREBRAS_TOKEN_QUOTA_WINDOW_SECONDS:-60}"
CAR_BENCH_CEREBRAS_RATE_LIMIT_REPORT_DIR = "${CAR_BENCH_CEREBRAS_RATE_LIMIT_REPORT_DIR:-/tmp/car-bench-rate-limit-reports}"
TRACK2_LLM_MALFORMED_RETRIES = "${TRACK2_LLM_MALFORMED_RETRIES:-1}"
LOGURU_LEVEL = "${LOGURU_LEVEL:-INFO}"

[config]
num_trials = 3
task_split = "hidden"
tasks_base_num_tasks = -1
tasks_hallucination_num_tasks = -1
tasks_disambiguation_num_tasks = -1
max_steps = 50
